    species        Ir
  #     global species definitions
      nucleus             77
      mass                192.217
  #
      l_hartree           4
  #
      cut_pot             3.5  1.5  1.0
      basis_dep_cutoff    1e-4
  #
      radial_base         72 5.0
      radial_multiplier   1
      angular_grids specified
        division   0.3664   50
        division   0.9423  110
        division   1.2652  194
        division   1.6525  302
