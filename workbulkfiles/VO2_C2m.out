  #  Definition of "minimal" basis
  #
  ################################################################################
  #     valence basis states
      valence      6  s   2.
      valence      5  p   6.
      valence      5  d   7.
      valence      4  f  14.
  #     ion occupancy
      ion_occ     6  s   1.
      ion_occ     5  p   6.
      ion_occ     5  d   6.
      ion_occ     4  f   14.
  ################################################################################
